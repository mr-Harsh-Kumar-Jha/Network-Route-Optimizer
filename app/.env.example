# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/network_route_optimizer

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# ── Pathfinding ───────────────────────────────────────────────────────────────
DEFAULT_PATHFINDING_STRATEGY=dijkstra

# ── Caching Proxy ─────────────────────────────────────────────────────────────
ROUTE_CACHE_ENABLED=true
ROUTE_CACHE_TTL_SECONDS=60
ROUTE_CACHE_MAX_SIZE=256
